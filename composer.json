{
    "name": "oceanmoon/math",
    "description": "PHP classes for Complex and Rational number arithmetic, plus Vector and Matrix operations.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "math",
        "complex",
        "rational",
        "fraction",
        "arithmetic",
        "vector",
        "matrix",
        "trigonometry"
    ],
    "authors": [
        {
            "name": "Shaun Moss",
            "email": "shaun@oceanmoon.software"
        }
    ],
    "homepage": "https://github.com/mossy2100/PHP-Math",
    "support": {
        "issues": "https://github.com/mossy2100/PHP-Math/issues",
        "source": "https://github.com/mossy2100/PHP-Math"
    },
    "require": {
        "php": "^8.4",
        "oceanmoon/core": "dev-main as 2.99.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0 || ^12.0",
        "squizlabs/php_codesniffer": "^4.0",
        "phpstan/phpstan": "^2.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "oceanmoon/coding-standard": "dev-main as 2.99.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../CodingStandard"
        },
        {
            "type": "path",
            "url": "../Core"
        }
    ],
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "autoload": {
        "psr-4": {
            "OceanMoon\\Math\\": "src/"
        },
        "files": [
            "src/bootstrap.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "OceanMoon\\Math\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "fix": "vendor/bin/phpcbf -vp",
        "check": "vendor/bin/phpcs -s",
        "report": "vendor/bin/phpcs -q --report=summary",
        "analyze": "scripts/analyze",
        "test": "php -d xdebug.mode=coverage vendor/bin/phpunit --coverage-html build/coverage --coverage-clover build/logs/clover.xml --do-not-cache-result",
        "coverage": "php scripts/coverage-check.php",
        "coverage-report": "open build/coverage/index.html",
        "quality": [
            "@fix",
            "@check",
            "@analyze",
            "@test",
            "@coverage"
        ]
    }
}
